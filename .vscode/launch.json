{
  "configurations": [
      {
          "name": "(gdb) Launch",
          "type": "cppdbg",
          "request": "launch",
          "program": "${workspaceFolder}/build/my_app",
          "args": [ ],
          "stopAtEntry": false,
          "cwd": "${fileDirname}",
          "environment": [],
          "externalConsole": false,
          "MIMode": "gdb",
          "miDebuggerPath": "/usr/bin/gdb",
          "setupCommands": [
              {
                  "description": "Enable pretty-printing for gdb",
                  "text": "-enable-pretty-printing",
                  "ignoreFailures": true
              },
              {
                  "description": "Ignore SIGPIPE",
                  "text": "handle SIGPIPE nostop noprint pass",
                  "ignoreFailures": true
              },
              {
                  "text": "set print object on",
                  "description": "enables to identify the actual (derived) type of an object",
                  "ignoreFailures": true
              }
          ]
      }
  ]
}