{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/include",
                "${workspaceFolder}/deps",
                "${workspaceFolder}/src"
            ],
            "compilerPath": "/usr/lib64/ccache/g++",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-gcc-x64",
            "compilerArgs": [
                "-Wall",
                "-Wextra",
                "-Wshadow",
                "-Wpedantic",
                "-Wconversion",
                "-Wsign-conversion",
                "-Wnull-dereference",
                "-Wduplicated-branches",
                "-Wduplicated-cond",
                "-Wlogical-op",
                "-Wnon-virtual-dtor",
                "-Wuseless-cast"
            ],
            "browse": {
                "path": [
                    "${workspaceFolder}/include",
                    "${workspaceFolder}/test",
                    "${workspaceFolder}/deps",
                    "${workspaceFolder}/src"
                ],
                "limitSymbolsToIncludedHeaders": true
            }
        }
    ],
    "version": 4
}
